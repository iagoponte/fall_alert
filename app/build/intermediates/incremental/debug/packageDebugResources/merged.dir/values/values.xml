<?xml version="1.0" encoding="utf-8"?>
<resources>
    <attr format="dimension" name="bottomNavigationHeight"/>
    <color name="error">#D85A30</color>
    <color name="error_container">#FAECE7</color>
    <color name="gray_600">#5F5E5A</color>
    <color name="green_50">#EAF3DE</color>
    <color name="green_700">#3B6D11</color>
    <color name="on_error">#FFFFFF</color>
    <color name="on_primary">#FFFFFF</color>
    <color name="on_primary_container">#085041</color>
    <color name="primary">#1D9E75</color>
    <color name="primary_container">#E1F5EE</color>
    <color name="surface">#FFFBFE</color>
    <color name="warning">#BA7517</color>
    <string name="app_name">QuedaAlerta</string>
    <string name="btn_activate">Ativar Monitoramento</string>
    <string name="btn_deactivate">Desativar Monitoramento</string>
    <string name="nav_contacts">Contatos</string>
